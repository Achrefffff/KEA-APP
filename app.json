{
  "expo": {
    "name": "KEA",
    "slug": "Application-kea",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ios_icon.png",
    "scheme": "applicationkea",
    "userInterfaceStyle": "light",
    "ios": {
      "icon": "./assets/images/ios_icon.png",
      "bundleIdentifier": "com.achraf.keashop"
    },
    "android": {
      "package": "com.achraf.keashop",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/KEA_adaptive_foreground.png",
        "monochromeImage": "./assets/images/KEA_adaptive_foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/KEA_NOIR_SANS_FOND-_3.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "image": "./assets/images/empty.png",
          "imageWidth": 200
        }
      ],
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false,
      "reactServerFunctions": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "72d42060-121a-45cd-bd45-a885a30b3e07"
      }
    }
  }
}
